      m_Calls: []
  m_text: "\uBAA9\uC801: \uC0AC\uC6A9\uC790\uAC00 \uC0DD\uC131\uD55C \uD654\uD559
    \uBAA8\uB378 \uD30C\uC77C\uC774\uB098 \uC2DC\uBBAC\uB808\uC774\uC158 \uACB0\uACFC\uB97C
    \uC800\uC7A5\uD558\uACE0 \uBD88\uB7EC\uC624\uB294 \uAE30\uB2A5\uC5D0 \uD544\uC694\uD569\uB2C8\uB2E4.\n\n\uAE30\uB2A5:
    \uBAA8\uB378\uB9C1 \uD30C\uC77C \uBC0F \uC2DC\uBBAC\uB808\uC774\uC158 \uB370\uC774\uD130\uB97C
    \uC7A5\uAE30\uC801\uC73C\uB85C \uC800\uC7A5\uD558\uACE0, \uD544\uC694 \uC2DC
    \uC5B8\uC81C\uB4E0\uC9C0 \uBD88\uB7EC\uC62C \uC218 \uC788\uB3C4\uB85D \uD569\uB2C8\uB2E4.
    \uAD8C\uD55C \uB3D9\uC758 \uC2DC, \uD574\uB2F9 \uAE30\uB2A5\uB4E4\uC744 \uC81C\uACF5\uD558\uAE30
    \uC704\uD574 \uD544\uC694\uD55C \uCD5C\uC18C\uD55C\uC758 \uC815\uBCF4\uB9CC\uC744
    \uC0AC\uC6A9\uD569\uB2C8\uB2E4. \uAC1C\uC778\uC815\uBCF4\uB294\_\uAC1C\uC778\uC815\uBCF4
    \uCC98\uB9AC\uBC29\uCE68\uC5D0 \uB530\uB77C \uC548\uC804\uD558\uAC8C \uBCF4\uD638\uB429\uB2C8\uB2E4.\r"
