  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uBAA9\uC801 : \uBCF8 \uC571\uC740 \uC6D0\uD65C\uD55C \uC11C\uBE44\uC2A4
    \uC81C\uACF5\uACFC \uBCF4\uC548 \uAC15\uD654\uB97C \uC704\uD574 \uAE30\uAE30
    \uBC0F \uC0AC\uC6A9 \uAE30\uB85D\uC744 \uD655\uC778\uD569\uB2C8\uB2E4.\n\n\uAE30\uB2A5
    : \uAE30\uAE30 \uC815\uBCF4(OS \uBC84\uC804, \uB2E8\uB9D0\uAE30 \uD658\uACBD)\uC640
    \uC571 \uC2E4\uD589\xB7\uC624\uB958 \uB85C\uADF8, \uB85C\uADF8\uC778 \uC774\uB825
    \uB4F1\uC744 \uC218\uC9D1\uD558\uBA70, \uC774\uB97C \uD1B5\uD574 \uC548\uC815\uC801\uC778
    \uC11C\uBE44\uC2A4 \uC6B4\uC601\uACFC \uB9DE\uCDA4\uD615 \uD559\uC2B5 \uAE30\uB2A5(\uCD5C\uADFC
    \uC774\uC6A9 \uB0B4\uC5ED, \uCD94\uCC9C \uCF58\uD150\uCE20)\uC744 \uC81C\uACF5\uD569\uB2C8\uB2E4.\r"
